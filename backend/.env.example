# PostgreSQL en Supabase. Copia este archivo a .env y rellena con tu proyecto.
# En Supabase: Project Settings → Database → Connection string (URI) o Connection pooling.

DB_HOST=aws-0-eu-central-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.TU_PROJECT_REF
DB_PASS=tu_password_supabase

# Opcional: poner DB_SSL=false solo si usas DB local sin SSL
# DB_SSL=false

# En producción mantener validación de certificado en true
DB_SSL_REJECT_UNAUTHORIZED=true

# Coma-separado para múltiples orígenes
ALLOWED_ORIGINS=http://localhost:8081

# Clave obligatoria para firmar JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Opcional: duración del token
JWT_EXPIRES_IN=8h

# URL pública del frontend para construir enlaces de verificación y recuperación.
APP_FRONTEND_URL=http://localhost:8081

# Modo de correo: "log" imprime el enlace en consola para desarrollo, "smtp" envía correos reales.
MAIL_MODE=log

# SMTP real para enviar verificación de cuenta y recuperación de contraseña.
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_password_smtp
SMTP_FROM=Smart Economato <no-reply@tu-dominio.com>

# Caducidad de enlaces
VERIFY_EMAIL_EXPIRES_HOURS=24
PASSWORD_RESET_EXPIRES_MINUTES=60
